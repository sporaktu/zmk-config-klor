#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
	chosen {
		zmk,kscan = &kscan0;
		// No zmk,matrix-transform here: with a physical layout the transform is
		// referenced by physical_layout0's `transform` property (required by Studio).
		zmk,physical-layout = &physical_layout0;
	};

	default_transform: keymap_transform {
		compatible = "zmk,matrix-transform";
		columns = <12>;
		rows = <4>;
		map = <
		        RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                 RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10)
		RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                 RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
		RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(3,5) RC(3,6) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
		                RC(3,1) RC(3,2) RC(3,3) RC(3,4)                 RC(3,7) RC(3,8) RC(3,9) RC(3,10)
		>;
	};

	physical_layout0: physical_layout_0 {
		compatible = "zmk,physical-layout";
		display-name = "Default Layout";
		transform = <&default_transform>;
		kscan = <&kscan0>;

		// Positions match klor.json; units are 1/100 of a key (100 = 1U).
		keys  //                     w   h    x    y     rot    rx    ry
			= <&key_physical_attrs 100 100  100   60       0     0     0>
			, <&key_physical_attrs 100 100  200   30       0     0     0>
			, <&key_physical_attrs 100 100  300    0       0     0     0>
			, <&key_physical_attrs 100 100  400   20       0     0     0>
			, <&key_physical_attrs 100 100  500   40       0     0     0>
			, <&key_physical_attrs 100 100  900   40       0     0     0>
			, <&key_physical_attrs 100 100 1000   20       0     0     0>
			, <&key_physical_attrs 100 100 1100    0       0     0     0>
			, <&key_physical_attrs 100 100 1200   30       0     0     0>
			, <&key_physical_attrs 100 100 1300   60       0     0     0>

			, <&key_physical_attrs 100 100    0  160       0     0     0>
			, <&key_physical_attrs 100 100  100  160       0     0     0>
			, <&key_physical_attrs 100 100  200  130       0     0     0>
			, <&key_physical_attrs 100 100  300  100       0     0     0>
			, <&key_physical_attrs 100 100  400  120       0     0     0>
			, <&key_physical_attrs 100 100  500  140       0     0     0>
			, <&key_physical_attrs 100 100  900  140       0     0     0>
			, <&key_physical_attrs 100 100 1000  120       0     0     0>
			, <&key_physical_attrs 100 100 1100  100       0     0     0>
			, <&key_physical_attrs 100 100 1200  130       0     0     0>
			, <&key_physical_attrs 100 100 1300  160       0     0     0>
			, <&key_physical_attrs 100 100 1400  160       0     0     0>

			, <&key_physical_attrs 100 100    0  260       0     0     0>
			, <&key_physical_attrs 100 100  100  260       0     0     0>
			, <&key_physical_attrs 100 100  200  230       0     0     0>
			, <&key_physical_attrs 100 100  300  200       0     0     0>
			, <&key_physical_attrs 100 100  400  220       0     0     0>
			, <&key_physical_attrs 100 100  500  240       0     0     0>
			, <&key_physical_attrs 100 100  600  260       0     0     0>
			, <&key_physical_attrs 100 100  800  260       0     0     0>
			, <&key_physical_attrs 100 100  900  240       0     0     0>
			, <&key_physical_attrs 100 100 1000  220       0     0     0>
			, <&key_physical_attrs 100 100 1100  200       0     0     0>
			, <&key_physical_attrs 100 100 1200  230       0     0     0>
			, <&key_physical_attrs 100 100 1300  260       0     0     0>
			, <&key_physical_attrs 100 100 1400  260       0     0     0>

			, <&key_physical_attrs 100 100  350  350       0     0     0>
			, <&key_physical_attrs 100 100  450  350       0     0     0>
			, <&key_physical_attrs 100 100  550  370       0     0     0>
			, <&key_physical_attrs 100 100  650  400       0     0     0>
			, <&key_physical_attrs 100 100  750  400       0     0     0>
			, <&key_physical_attrs 100 100  850  370       0     0     0>
			, <&key_physical_attrs 100 100  950  350       0     0     0>
			, <&key_physical_attrs 100 100 1050  350       0     0     0>
			;
	};


	kscan0: kscan {
		compatible = "zmk,kscan-gpio-matrix";
		label = "KSCAN";
		wakeup-source;

		diode-direction = "col2row";
		row-gpios
			= <&pro_micro 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			, <&pro_micro 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			, <&pro_micro 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			, <&pro_micro 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			;
	};

	left_encoder: encoder_left {
		compatible = "alps,ec11";
		label = "LEFT_ENCODER";
		a-gpios = <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
		b-gpios = <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
		resolution = <4>;
		//status = "disabled";
	};

	right_encoder: encoder_right {
		compatible = "alps,ec11";
		label = "RIGHT_ENCODER";
		a-gpios = <&pro_micro 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
		b-gpios = <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
		resolution = <4>;
		status = "disabled";
	};

	sensors {
		compatible = "zmk,keymap-sensors";
		sensors = <&left_encoder>;
	};
};
